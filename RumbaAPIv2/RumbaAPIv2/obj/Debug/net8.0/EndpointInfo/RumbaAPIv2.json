  "components": {
    "schemas": {
      "ClienteUpsertDto": {
        "required": [
          "nombre"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "instagram": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "telefono": {
            "maxLength": 20,
            "type": "string",
            "nullable": true
          },
          "notas": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "EliminarVariosDto": {
        "required": [
          "ids"
        ],
        "type": "object",
        "properties": {
          "ids": {
            "type": "array",
            "items": {
              "type": "integer",
              "format": "int32"
            }
          }
        },
        "additionalProperties": false
      },
      "LoginDto": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string"
          },
          "password": {
            "minLength": 1,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RegisterDto": {
        "required": [
          "email",
          "name",
          "password",
          "username"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 100,
            "minLength": 1,
            "type": "string"
          },
          "username": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9_]+$",
            "type": "string"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "password": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RumbaUpsertDto": {
        "required": [
          "nombre"
        ],
        "type": "object",
        "properties": {
          "nombre": {
            "maxLength": 200,
            "minLength": 1,
            "type": "string"
          },
          "tipo": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "estado": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "pagado": {
            "type": "boolean"
          },
          "montoPago": {
            "maxLength": 50,
            "type": "string",
            "nullable": true
          },
          "fechaEntrega": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "notas": {
            "type": "string",
            "nullable": true
          },
          "urgente": {
            "type": "boolean"
          },
          "ep": {
            "maxLength": 100,
            "type": "string",
            "nullable": true
          },
          "clienteId": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "type": "integer",
            "format": "int32"
          },
          "temperatureF": {
            "type": "integer",
            "format": "int32",
            "readOnly": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Pega el token JWT aquí. Ejemplo: Bearer eyJhbG...",
        "scheme": "Bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
